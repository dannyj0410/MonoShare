{
  "compilerOptions": {
    "typeRoots": ["./node_modules/@types", "./src/@types", "./src/types"],
    "module": "Node16",
    "moduleResolution": "node16",
    "strict": true,
    "outDir": "./built",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "esModuleInterop": true,
    "types": ["node"]
  },
  "include": ["src/**/*"]
}
